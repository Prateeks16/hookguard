# Sample protected application — verifies only the Gateway signature.
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/upstream ./cmd/upstream

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/upstream /upstream
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/upstream"]
