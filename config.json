{
  "routes": [
    {
      "path": "/hook/stripe",
      "provider": "stripe",
      "upstream": "http://localhost:8080/stripe",
      "replay_window": "5m",
      "secret_env": "STRIPE_SECRET"
    },
    {
      "path": "/hook/github",
      "provider": "github",
      "upstream": "http://localhost:8080/github",
      "secret_env": "GITHUB_SECRET"
    },
    {
      "path": "/hook/shopify",
      "provider": "shopify",
      "upstream": "http://localhost:8080/shopify",
      "secret_env": "SHOPIFY_SECRET"
    }
  ]
}
